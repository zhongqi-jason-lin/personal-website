# Files excluded from the static-asset bundle served by the Worker.
# Server code and config live in the repo but shouldn't be reachable via HTTP.
worker/
wrangler.jsonc
wrangler.toml
.assetsignore
# Local dev server state — miniflare sqlite caches, tmp compiled worker bundle.
# Without this entry, `wrangler deploy` uploads them as static assets.
.wrangler/
.dev.vars
.env
.env.*
package.json
package-lock.json
node_modules/
.git/
.gitignore
README.md
project/
*.md
.DS_Store
**/.DS_Store
# Tooling-generated state — Claude Code config, brainstorm artifacts.
# These are local-only and must never be reachable via the public site.
.claude/
.superpowers/
